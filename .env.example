# ============================================
# 钉钉配置（二选一）
# ============================================

# 方式1: 自定义机器人（Webhook）- 简单快速
# 获取方式：钉钉群 -> 智能群助手 -> 添加机器人 -> 自定义
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
# 钉钉加签密钥（可选，如果机器人使用了加签安全设置）
DINGTALK_SECRET=

# 方式2: 企业内部应用（AppKey/AppSecret）- 功能更强大
# 获取方式：钉钉开发者后台 -> 应用开发 -> 企业内部开发 -> 创建应用
# 如果使用此方式，可以不配置上面的WEBHOOK
DINGTALK_APPKEY=
DINGTALK_APPSECRET=
DINGTALK_AGENT_ID=
# 接收消息的用户ID列表（逗号分隔），留空则发给所有人
DINGTALK_USER_IDS=

# AI模型配置（支持OpenAI兼容接口）
# 支持的模型：
# 1. OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# 2. 国内大模型：
#    - 通义千问(阿里云): qwen-max, qwen-plus, qwen-turbo
#    - 腾讯混元: hunyuan-lite, hunyuan-standard, hunyuan-pro
#    - 文心一言(百度): ERNIE-4.0-8K, ERNIE-3.5-8K
#    - 智谱AI: glm-4, glm-3-turbo
#    - DeepSeek: deepseek-chat
#    - Moonshot(月之暗面): moonshot-v1-8k
#    - 零一万物: yi-large, yi-medium
# 3. 开源模型(通过兼容接口): llama3, qwen2等

OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4

# 股票池配置（逗号分隔）
STOCK_POOL=000001,600519,000858,601318

# 推送时间配置
PUSH_TIME=09:00,15:30
